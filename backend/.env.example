# ===================================
# 🗄️ DATABASE - SUPABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
# ===================================

# ===================================
# 🌐 SUPABASE API KEYS
# ===================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY_HERE

# ===================================
# SECRET KEYS
# ===================================
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_SECRET_KEY_HERE
JWT_SECRET=placeholder_jwt_secret_minimum_32_characters_required
SESSION_SECRET=placeholder_session_secret_minimum_32_characters_required

# ===================================
# 🌍 SERVER
# ===================================
PORT=3001
NODE_ENV=production

# ===================================
# 🔗 URLs (Render bilan)
# ===================================
FRONTEND_URL=https://davomatchi.vercel.app/
BACKEND_URL=https://davomatchi.onrender.com